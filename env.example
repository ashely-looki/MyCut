# AutoClip 环境变量配置示例
# 复制此文件为 .env 并填入实际配置

# 数据库配置
DATABASE_URL=sqlite:///./data/autoclip.db

# Redis配置
REDIS_URL=redis://localhost:6379/0

# API配置
API_DASHSCOPE_API_KEY=your_dashscope_api_key_here
API_MODEL_NAME=qwen-plus
API_MAX_TOKENS=4096
API_TIMEOUT=30

# 处理配置
PROCESSING_CHUNK_SIZE=5000
PROCESSING_MIN_SCORE_THRESHOLD=0.7
PROCESSING_MAX_CLIPS_PER_COLLECTION=5
PROCESSING_MAX_RETRIES=3

# 路径配置（可选，系统会自动检测）
# PATH_PROJECT_ROOT=
# PATH_DATA_DIR=
# PATH_UPLOADS_DIR=
# PATH_TEMP_DIR=
# PATH_OUTPUT_DIR=

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=backend.log

# 环境配置
ENVIRONMENT=development
DEBUG=true

# ---- Supabase 认证（后端校验前端传来的 JWT）----
# AUTH_ENABLED=true 且填了 SUPABASE_JWT_SECRET 时，projects 接口才强制登录并按用户隔离。
# 留空 / false：后端不强制登录，老数据归属到本地用户（本地调试）。
# JWT secret 在 Supabase 控制台 Project Settings → API → JWT Settings → JWT Secret。
SUPABASE_URL=
SUPABASE_JWT_SECRET=
AUTH_ENABLED=false

# ---- 支付宝支付（电脑网站支付 alipay.trade.page.pay）----
# ALIPAY_ENABLED=true 且 APPID/应用私钥/支付宝公钥齐全时才启用支付接口。
# 沙箱：open.alipay.com/develop/sandbox/app 拿 APPID、买家账号；自己生成密钥对，
#       上传应用公钥，换回支付宝公钥。网关用沙箱地址。
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_SERVER_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_SIGN_TYPE=RSA2
# 密钥推荐用文件路径（多行 PEM 不适合塞进单行 env）；也可用 *_KEY 直接填（换行写成 \n）。
ALIPAY_APP_PRIVATE_KEY_PATH=
ALIPAY_PUBLIC_KEY_PATH=
# ALIPAY_APP_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# 异步通知地址（必须公网可达；本地沙箱可用内网穿透，或先不填靠前端轮询兜底）
ALIPAY_NOTIFY_URL=
# 付款后浏览器同步跳回地址（仅展示用）
ALIPAY_RETURN_URL=
# 月会员单价（元）
MEMBERSHIP_MONTH_PRICE=98.00 