# MyCut 生产环境配置模板。
# 用法：复制为 .env.production 并按下面说明填写，然后 docker compose up -d --build。
# 注意：.env.production 已被 .gitignore / .dockerignore 排除，不会入库、不会进镜像。

# ================= 运行模式 =================
# 容器内用「桌面语义后台线程」执行任务，免 Redis（compose 已设 AUTOCLIP_DESKTOP_MODE=1）。
# 数据目录由 compose 挂持久卷到 /app/data。
ENVIRONMENT=production
DEBUG=false

# FFmpeg：容器内走系统 PATH（apt 装的 /usr/bin/ffmpeg），无需再写死路径。
# 若坚持指定可用：AUTOCLIP_FFMPEG_PATH=/usr/bin/ffmpeg

# ================= 数据库 =================
# 默认用 /app/data 下的 SQLite（单机单容器足够）。
DATABASE_URL=sqlite:///./data/autoclip.db
# 若将来上 Postgres（如 Supabase 自带库），改成：
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ================= LLM（DeepSeek，OpenAI 兼容）=================
# 推荐启动后在「设置页」填 key（存 /app/data/settings.json，随持久卷保留）；
# 也可在此用环境变量注入。
API_MODEL_NAME=qwen-plus
API_MAX_TOKENS=4096
API_TIMEOUT=30

# ================= 处理参数 =================
PROCESSING_CHUNK_SIZE=5000
PROCESSING_MIN_SCORE_THRESHOLD=0.7
PROCESSING_MAX_CLIPS_PER_COLLECTION=5
PROCESSING_MAX_RETRIES=3
LOG_LEVEL=INFO

# ================= CORS =================
# 同源部署（nginx 反代 /api，前后端同域）：留空即可，最安全。
# 前后端分离部署：填精确域名，逗号分隔，例如：
# CORS_ALLOW_ORIGINS=https://mycut.example.com,https://www.mycut.example.com
CORS_ALLOW_ORIGINS=

# ================= Supabase 认证 =================
# 开启注册登录 + 按用户隔离项目。同源部署下前端相对路径即可。
SUPABASE_URL=
SUPABASE_JWT_SECRET=
AUTH_ENABLED=false

# ================= 支付宝支付 =================
# 前置：需企业/个体工商户资质并在开放平台签约「电脑网站支付」，个人号无法上生产。
# ALIPAY_ENABLED=false 时支付接口返回 503，不影响其它功能。
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
# 生产网关（沙箱是 openapi-sandbox.dl.alipaydev.com）：
ALIPAY_SERVER_URL=https://openapi.alipay.com/gateway.do
ALIPAY_SIGN_TYPE=RSA2
# 密钥 PEM：放宿主机 ./secrets 下，compose 以只读卷挂到 /app/secrets。
ALIPAY_APP_PRIVATE_KEY_PATH=/app/secrets/alipay_app_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/app/secrets/alipay_public_key.pem
# 生产必须公网可达（支付宝异步通知发货）：
ALIPAY_NOTIFY_URL=https://mycut.example.com/api/v1/pay/alipay/notify
ALIPAY_RETURN_URL=https://mycut.example.com/#/membership
MEMBERSHIP_MONTH_PRICE=98.00

# ================= 成片资源控制（小内存服务器很重要）=================
# Remotion 渲染并发：每个并发 = 一个 headless Chromium（1080p 下每个吃 0.3~0.7G）。
# 2核4G 机器建议 2；4核8G 可设 3~4 加速；1G 小机可设 1。默认 2。
REMOTION_CONCURRENCY=2
# Higgsfield 实拍并发（纯网络等待，几乎不吃 CPU/内存），默认 4：
# HIGGSFIELD_CONCURRENCY=4

# ================= 成片外部服务（可选，不填自动降级）=================
# Higgsfield（实拍空镜）需登录态；容器内未登录会自动回退信息动画，成片仍产出。
# HIGGSFIELD_DISABLE=1   # 显式关闭实拍，全走信息动画
# HIGGSFIELD_MAX_CREDITS=... # 生成额度上限保护
